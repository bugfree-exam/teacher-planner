generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StudentStatus {
  ACTIVE
  PAUSED
  FINISHED
}

enum SocialType {
  TELEGRAM
  VK
  WHATSAPP
  OTHER
}

enum LessonType {
  TRIAL
  REGULAR
}

enum LessonStatus {
  PLANNED
  COMPLETED
  CANCELLED
  MOVED
}

enum PaymentType {
  LESSON
  ADVANCE
  MONTH
  PACKAGE
}

enum HomeworkStatus {
  ASSIGNED
  DONE
  CHECKED
  OVERDUE
}

enum TopicStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Student {
  id         String      @id @default(cuid())
  fullName   String
  phone      String?
  socialType SocialType?
  socialLink String?

  parentName  String?
  parentPhone String?
  parentEmail String?

  startedAt   DateTime?
  defaultRate Int?
  grade       Int?
  sourceName  String?
  sourceLink  String?

  desiredResult String?
  actualScore   Int?
  university    String?
  direction     String?

  status StudentStatus @default(ACTIVE)

  lessons       Lesson[]
  payments      Payment[]
  groupStudents GroupStudent[]
  homeworks     Homework[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes StudentNote[]

  topics TopicProgress[]
}

model Group {
  id          String  @id @default(cuid())
  name        String
  description String?
  defaultRate Int?
  isActive    Boolean @default(true)

  students  GroupStudent[]
  lessons   Lesson[]
  homeworks Homework[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topics TopicProgress[]
}

model GroupStudent {
  id String @id @default(cuid())

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([groupId, studentId])
}

model Lesson {
  id String @id @default(cuid())

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  startsAt    DateTime
  durationMin Int

  type   LessonType   @default(REGULAR)
  status LessonStatus @default(PLANNED)

  price Int
  note  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topicId  String?
  topic    Topic?     @relation(fields: [topicId], references: [id], onDelete: SetNull)
  homework Homework[]
}

model Payment {
  id String @id @default(cuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  amount  Int
  paidAt  DateTime
  type    PaymentType @default(LESSON)
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Homework {
  id String @id @default(cuid())

  title       String
  description String?
  deadline    DateTime?
  status      HomeworkStatus @default(ASSIGNED)

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  lessonId String?
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([groupId])
  @@index([topicId])
  @@index([lessonId])
}

model StudentNote {
  id        String   @id @default(cuid())

  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  content   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model TopicProgress {
  id String @id @default(cuid())

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  status   TopicStatus @default(NOT_STARTED)
  note     String?
  progress Int         @default(0)

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, topicId])
  @@unique([groupId, topicId])
  @@index([studentId])
  @@index([groupId])
  @@index([topicId])
}

model Topic {
  id String @id @default(cuid())

  title       String
  description String?
  subject     String?
  grade       Int?
  order       Int     @default(0)
  isActive    Boolean @default(true)

  progresses TopicProgress[]
  lessons    Lesson[]
  homeworks  Homework[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([grade])
  @@index([subject])
}
